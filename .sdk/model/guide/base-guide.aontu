# Guide

guide: {
  metrics: count: entity: 2
  metrics: count: path: 3
  metrics: count: method: 3

  entity: card: {
    path: "/cards": {
      op: list: method: *GET
    }
    path: "/cards/{id}": {
      op: load: method: *GET
      op: load: transform: res: *("`body.card`")|top
    }
  }

  entity: set: {
    path: "/sets": {
      op: list: method: *GET
    }
  }

}